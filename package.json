{
    "name": "filemind-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:python\" \"npm run dev -w @filemind/worker\" \"npm run dev -w frontend\"",
        "dev:python": "cd packages/backend-python && .\\venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8000",
        "build": "npm run build --workspaces --if-present",
        "vercel-build": "npm run build -w frontend",
        "start": "npm run start --workspaces --if-present"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}